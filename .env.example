VITE_N8N_WEBHOOK_URL=https://your-n8n-domain.example/webhook/property-onboarding

APPFOLIO_URL=https://thetgpm.appfolio.com
APPFOLIO_USERNAME=
APPFOLIO_PASSWORD=

# Dedicated onboarding AppFolio browser session/profile. Do not share renewal's live profile.
PLAYWRIGHT_USER_DATA_DIR=/root/appfolio-property-onboarding/.playwright-appfolio-profile
HEADLESS=true
PLAYWRIGHT_SLOW_MO=80
APPFOLIO_MFA_CODE=
APPFOLIO_LOGIN_TIMEOUT_MS=60000
APPFOLIO_ACTION_TIMEOUT_MS=30000
APPFOLIO_DIAGNOSTIC_MODE=true
APPFOLIO_TRAINING_PAUSE_ON_ERROR=true
START_SECTION=

PROPERTY_ONBOARDING_SPREADSHEET_ID=1VNjBAp_19s7ShBFHmF6u-w2crGnywCZogy4CgQcrHHU
PROPERTY_ONBOARDING_TAB=Property_Onboarding
PROPERTY_ONBOARDING_ROW=

# Set true for selector mapping walkthroughs that should skip the final Bank Accounts Save.
APPFOLIO_PROPERTY_DRY_RUN=false

GOOGLE_OAUTH_CLIENT_JSON=/root/appfolio-property-onboarding/client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=/root/appfolio-property-onboarding/.appfolio-google-token.json
